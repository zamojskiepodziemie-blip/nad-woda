.82,lo:16.65},{n:'Gosp. Wrocław',t:'paid',f:['Karp','Amur','Sum'],c:'71 234 56 78',h:'6-21',l:'Wrocław',la:51.1,lo:17.03},{n:'Stawy Dzierżoniów',t:'paid',f:['Karp','Tołpyga','Lin'],c:'74 345 67 89',h:'7-19',l:'Dzierżoniów',la:50.73,lo:16.62}],'opolskie':[{n:'Jezioro Nyskie',t:'pzw',f:['Szczupak','Okon','Karp','Węgorz'],h:'cały rok',l:'Nysa',la:50.48,lo:17.33},{n:'Jezioro Otmuchowskie',t:'pzw',f:['Szczupak','Karp','Leszcz','Węgorz'],h:'cały rok',l:'Otmuchów',la:50.47,lo:17.18},{n:'Gosp. Opole',t:'paid',f:['Karp','Sum','Amur'],c:'77 123 45 67',h:'6-20',l:'Opole',la:50.64,lo:17.93},{n:'Stawy Kędzierzyn',t:'paid',f:['Karp','Tołpyga','Lin'],c:'77 234 56 78',h:'7-19',l:'Kędzierzyn-Koźle',la:50.34,lo:18.22}],'slaskie':[{n:'Zbiornik Łączany',t:'pzw',f:['Karp','Amur','Szczupak'],h:'cały rok',l:'Łączany',la:49.95,lo:18.85},{n:'Jezioro Żywieckie',t:'pzw',f:['Pstrąg','Karaś','Lipień'],h:'cały rok',l:'Żywiec',la:49.68,lo:19.18},{n:'Gosp. Katowice',t:'paid',f:['Karp','Sum','Tołpyga'],c:'32 123 45 67',h:'6-21',l:'Katowice',la:50.26,lo:19.02},{n:'Stawy Czechowice',t:'paid',f:['Karp','Lin','Tołpyga'],c:'32 234 56 78',h:'7-19',l:'Czechowice-Dziedzice',la:49.92,lo:19.02}],'swietokrzyskie':[{n:'Zbiornik Brody',t:'pzw',f:['Karp','Leszcz','Płotka'],h:'cały rok',l:'Brody',la:51.15,lo:20.65},{n:'Jezioro Świdnickie',t:'pzw',f:['Szczupak','Okon','Karp'],h:'cały rok',l:'Świdnica',la:50.85,lo:16.48},{n:'Gosp. Kielce',t:'paid',f:['Karp','Amur','Sum'],c:'41 123 45 67',h:'6-20',l:'Kielce',la:50.87,lo:20.63},{n:'Stawy Ćmielów',t:'paid',f:['Karp','Amur'],c:'15 234 56 78',h:'8-18',l:'Ćmielów',la:50.88,lo:21.28}],'malopolskie':[{n:'Zbiornik Czchów',t:'pzw',f:['Pstrąg','Karaś','Płotka'],h:'cały rok',l:'Czchów',la:49.73,lo:20.7},{n:'Jezioro Rożnowskie',t:'pzw',f:['Pstrąg','Lipień','Karaś','Szczupak'],h:'cały rok',l:'Nowy Sącz',la:49.63,lo:20.7},{n:'Gosp. Kraków',t:'paid',f:['Karp','Sum','Amur'],c:'12 123 45 67',h:'6-21',l:'Kraków',la:50.06,lo:19.94},{n:'Stawy Okocim',t:'paid',f:['Karp','Amur','Sum'],c:'14 234 56 78',h:'6-22',l:'Okocim',la:49.95,lo:20.55}],'podkarpackie':[{n:'Jezioro Solińskie',t:'pzw',f:['Pstrąg','Lipień','Karaś','Szczupak'],h:'cały rok',l:'Solina',la:49.42,lo:22.48},{n:'Zbiornik Myczkowce',t:'pzw',f:['Pstrąg','Karaś','Lipień'],h:'cały rok',l:'Myczkowce',la:49.38,lo:22.38},{n:'Jezioro Lanc Korocka',t:'pzw',f:['Szczupak','Okon','Karp'],h:'cały rok',l:'Lanc',la:49.45,lo:22.65},{n:'Gosp. Rzeszów',t:'paid',f:['Karp','Amur','Sum'],c:'17 123 45 67',h:'6-20',l:'Rzeszów',la:50.04,lo:22},{n:'Stawy Zaleszany',t:'paid',f:['Karp','Amur','Tołpyga'],c:'17 234 56 78',h:'6-20',l:'Zaleszany',la:50.25,lo:21.65}]};
var aktualne=null;
var filtr='all';
var wybrane=null;
function wybierzWoj(w){aktualne=w;document.getElementById('mapaWidok').classList.add('hidden');document.getElementById('puste').classList.add('hidden');document.getElementById('wstecz').classList.remove('hidden');document.getElementById('tytulWoj').classList.remove('hidden');document.getElementById('tytulWoj').innerText='Łowiska - '+w;document.getElementById('filtry').classList.remove('hidden');render();}
function wroc(){aktualne=null;document.getElementById('mapaWidok').classList.remove('hidden');document.getElementById('puste').classList.remove('hidden');document.getElementById('wstecz').classList.add('hidden');document.getElementById('tytulWoj').classList.add('hidden');document.getElementById('filtry').classList.add('hidden');document.getElementById('lista').innerHTML='';filtr='all';document.getElementById('btnW').className='btn active';document.getElementById('btnP').className='btn';document.getElementById('btnZ').className='btn';}
function ustawFiltr(f){filtr=f;document.getElementById('btnW').className='btn'+(f==='all'?' active':'');document.getElementById('btnP').className='btn'+(f==='paid'?' active':'');document.getElementById('btnZ').className='btn'+(f==='pzw'?' active':'');render();}
function render(){var l=document.getElementById('lista');l.innerHTML='';if(!aktualne||!lowiska[aktualne])return;var arr=lowiska[aktualne];if(filtr!=='all'){arr=arr.filter(function(x){return x.t===filtr;});}
arr.forEach(function(x,i){var d=document.createElement('div');d.className='item';d.innerHTML='<h3>'+x.n+'</h3><span class="typ '+x.t+'">'+(x.t==='paid'?'Płatne':'PZW')+'</span><p>📍 '+x.l+'</p>';d.onclick=function(){pokazLowisko(i);};l.appendChild(d);});if(arr.length===0){l.innerHTML='<div class="puste"><p>Brak łowisk w tym regionie</p></div>';}}
function pokazLowisko(i){var arr=lowiska[aktualne];if(filtr!=='all'){arr=arr.filter(function(x){return x.t===filtr;});}
wybrane=arr[i];document.getElementById('mTytul').innerText=wybrane.n;document.getElementById('mTyp').innerText=wybrane.t==='paid'?'Płatne':'PZW';document.getElementById('mTyp').className='typ '+wybrane.t;var ryby='';for(var j=0;j<wybrane.f.length;j++){ryby+='<span class="tag">'+wybrane.f[j]+'</span>';}
document.getElementById('mRyby').innerHTML=ryby;if(wybrane.t==='paid'){document.getElementById('mKontaktSekc').classList.remove('hidden');document.getElementById('mKontakt').innerText=wybrane.c;}else{document.getElementById('mKontaktSekc').classList.add('hidden');}
document.getElementById('mGodziny').innerText=wybrane.h;document.getElementById('mLokal').innerText=wybrane.l;document.getElementById('mTrasa').href='https://www.google.com/maps/dir/?api=1&destination='+wybrane.la+','+wybrane.lo;document.getElementById('modal').classList.add('aktywna');}
function zamknijModal(){document.getElementById('modal').classList.remove('aktywna');}
</script>
</body>
</html>